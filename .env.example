# ==============================================================================
# LUCY SYSTEM ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# The URL must match your SQL Server setup
LUCY_DB_URL=jdbc:sqlserver://localhost;instanceName=SQLEXPRESS;databaseName=LUCY_DBS;encrypt=false;trustServerCertificate=true;
LUCY_DB_USER=lucy_admin
LUCY_DB_PASSWORD=replace_with_local_password

# --- CORS & FRONTEND CONFIGURATION ---
# The URL of your React frontend application
LUCY_ALLOWED_ORIGIN=http://localhost:5173

# --- FRONTEND API BASE URL ---
# The URL of your Tomcat Backend API
VITE_LUCY_API_BASE=http://localhost:8080/LucyBackendAPI
VITE_AGORA_TOKEN_BASE=http://localhost:3000
VITE_AGORA_APP_ID=your_agora_app_id_here

# --- MICROSERVICE ENVIRONMENT SETTINGS ---
LUCY_PAYMENT_API_BASE=http://localhost:5000
LUCY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LUCY_ENABLE_SWAGGER=true
GEMINI_API_KEY=replace_with_optional_key

# --- VIETQR BANK TRANSFER CONFIGURATION ---
# Bank code/BIN accepted by VietQR (examples: MB, VCB, TCB)
VITE_PAYMENT_BANK_ID=replace_with_bank_code
VITE_PAYMENT_ACCOUNT_NO=replace_with_account_number
VITE_PAYMENT_ACCOUNT_NAME=replace_with_account_holder_name
